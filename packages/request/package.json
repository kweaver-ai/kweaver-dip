{
  "name": "@kweaver-web/request",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "query-string": "^9.3.1"
  },
  "devDependencies": {
    "@kweaver-web/tsconfig": "workspace:*",
    "@kweaver-web/tsup-config": "workspace:*",
    "typescript": "^5.9.3"
  }
}
